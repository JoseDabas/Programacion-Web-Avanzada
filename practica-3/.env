SPRING_APPLICATION_NAME=mockup-api

# Configuración H2
DB_HOST=db
DB_NAME=mockup_db
DB_USER=sa
DB_PASSWORD=

# Puertos Host
APP_PORT=8080
ADMIN_PORT=8082

# Ruta física para guardar los datos (crea la carpeta data/h2 primero)
DB_VOLUME_PATH=data/h2

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_MESSAGES_BASENAME=messages/messages
SPRING_MESSAGES_ENCODING=UTF-8
